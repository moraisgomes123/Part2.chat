<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="900"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#252526"
                CornerRadius="10"
                Padding="15"
                Margin="0 0 0 10">

            <StackPanel>

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="Cyan"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online!"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,10"/>

                <TextBlock Name="AsciiBanner"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="Cyan"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA (FIXED) -->
        <RichTextBox Name="ChatDisplay"
                     Grid.Row="1"
                     IsReadOnly="True"
                     Background="#2D2D30"
                     FontSize="14"
                     Foreground="White"
                     VerticalScrollBarVisibility="Auto"/>

        <!-- INPUT -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0 10 0 0">

            <TextBox Name="UserInput"
                     Width="700"
                     Height="40"
                     FontSize="14"/>

            <Button Content="Send"
                    Width="120"
                    Height="40"
                    Margin="10 0 0 0"
                    Background="Cyan"
                    Click="SendButton_Click"/>
        </StackPanel>

    </Grid>
</Window>